{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/safeguarding-monitor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/inspection-snapshots-cron",
      "schedule": "0 2 1 * *"
    }
  ]
}